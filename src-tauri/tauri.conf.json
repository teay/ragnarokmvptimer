{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ragnarok-mvp-timer",
  "version": "0.1.0",
  "identifier": "ragnarok-mvp-timer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ragnarok MVP Timer",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "theme": "Dark",
        "visible": false,
        "background_color": [5, 5, 5, 255]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
